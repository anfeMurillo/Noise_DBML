Project Ecommerce_Enterprise {
  database_type: 'PostgreSQL'
  Note: '''
    # E-commerce Global Database
    Esquema validado al 100% con sintaxis de pago de dbdiagram.io:
    - Multi-schema (Auth, Sales, Catalog)
    - Relaciones Many-to-Many nativas sin tabla intermedia (`<>`)
    - Colores en cabeceras de tablas (`headercolor`)
    - Colores en flechas de relaciones (`color`)
    - Colores en Grupos de Tablas (`color`)
  '''
}

// ==========================================
// 1. ESQUEMA DE SEGURIDAD (AUTH)
// ==========================================

Table auth.users as U [headercolor: #2b3a42] {
  id uuid [primary key, default: `gen_random_uuid()`]
  email varchar [unique, not null]
  password_hash text [not null]
  status user_status [default: 'active']
  created_at timestamp [default: `now()`]
  
  Note: 'Tabla maestra de usuarios'
}

Table auth.permissions [headercolor: #2b3a42] {
  id integer [primary key]
  name varchar [unique]
  description text
}

// Relación Muchos-a-Muchos nativa (genera visualmente la conexión directa)
Ref users_permissions: auth.users.id <> auth.permissions.id [color: #e74c3c]

// ==========================================
// 2. ESQUEMA DE CATÁLOGO (CATALOG)
// ==========================================

Table catalog.categories [headercolor: #e67e22] {
  id integer [primary key]
  parent_id integer [note: 'Permite jerarquías infinitas']
  name varchar
}

// Relación Recursiva (Categoría padre a subcategoría)
Ref: catalog.categories.parent_id > catalog.categories.id [color: #e67e22]

Table catalog.products [headercolor: #e67e22] {
  id uuid [primary key]
  category_id integer
  sku varchar [unique]
  name varchar
  price decimal(10,2) [not null]
  tags jsonb [note: 'Permite búsqueda indexada en campos JSON']
  
  Indexes {
    // Índice compuesto con nombre y tipo de algoritmo explícito
    (category_id, price) [name: 'idx_product_cat_price', type: btree]
    sku [unique]
  }
}

Ref: catalog.products.category_id > catalog.categories.id [color: #e67e22]

// ==========================================
// 3. ESQUEMA DE VENTAS (SALES)
// ==========================================

Table sales.orders [headercolor: #27ae60] {
  id uuid [primary key]
  user_id uuid
  status order_status [default: 'pending']
  total decimal(12,2)
  created_at timestamp
}

// Relación Uno-a-Muchos cruzando diferentes esquemas
Ref: sales.orders.user_id > auth.users.id [color: #27ae60]

Table sales.order_items [headercolor: #27ae60] {
  id integer [primary key]
  order_id uuid
  product_id uuid
  quantity integer [not null, default: 1]
  unit_price decimal(10,2)
  
  Indexes {
    (order_id, product_id) [unique]
  }
}

// Relación con regla de borrado en cascada
Ref: sales.order_items.order_id > sales.orders.id [delete: cascade, color: #27ae60]
Ref: sales.order_items.product_id > catalog.products.id [color: #e67e22]

// ==========================================
// 4. DEFINICIÓN DE ENUMS
// ==========================================

enum user_status {
  active
  suspended
  banned
}

enum order_status {
  pending
  processing
  shipped
  delivered
}

// ==========================================
// 5. GRUPOS DE TABLAS (Con nombres y colores)
// ==========================================

TableGroup "Security & Access" [color: #2b3a42] {
  auth.users
  auth.permissions
}

TableGroup "Inventory Management" [color: #e67e22] {
  catalog.categories
  catalog.products
}

TableGroup "Sales & Transactions" [color: #27ae60] {
  sales.orders
  sales.order_items
}