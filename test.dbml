// E-commerce Project Example
Project ecommerce {
  database_type: 'PostgreSQL'
  Note: '''
  # E-Commerce Database
  Complete schema for an online store.
  '''
}

// Enums
enum order_status {
  pending [note: 'Waiting to be processed']
  processing
  shipped
  delivered
  cancelled
}

enum user_role {
  admin
  moderator
  customer
}

// Reusable Partials
TablePartial timestamps {
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
}

// Tables
Table users [headercolor: #3498DB] {
  id integer [pk, increment]
  username varchar(255) [not null, unique]
  email varchar(255) [not null, unique]
  full_name varchar(255)
  role user_role [not null, default: 'customer']
  ~timestamps

  Note: 'System users table'

  indexes {
    email [unique, name: 'users_email_idx']
    (username, email) [unique]
  }
}

Table merchants {
  id integer [pk, increment]
  name varchar(255) [not null]
  country_code varchar(2) [not null]
  ~timestamps
}

Table products [headercolor: #2ECC71] {
  id integer [pk, increment]
  name varchar(255) [not null]
  description text
  price decimal(10,2) [not null, default: 0]
  stock integer [not null, default: 0, check: `stock >= 0`]
  merchant_id integer [not null]
  ~timestamps
}

Table orders {
  id integer [pk, increment]
  user_id integer [not null]
  status order_status [not null, default: 'pending']
  total decimal(10,2) [not null]
  ~timestamps
}

Table order_items {
  id integer [pk, increment]
  order_id integer [not null]
  product_id integer [not null]
  quantity integer [not null, check: `quantity > 0`]
  unit_price decimal(10,2) [not null]
}

// Relationships
Ref: products.merchant_id > merchants.id [delete: cascade]
Ref: orders.user_id > users.id [delete: restrict]
Ref: order_items.order_id > orders.id [delete: cascade]
Ref: order_items.product_id > products.id [delete: restrict]

// Table Groups
TableGroup core [color: #3498DB] {
  users
  merchants
}

TableGroup commerce [color: #2ECC71] {
  products
  orders
  order_items
}
